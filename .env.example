# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/league247
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_KEY=...

# --- Redis (Upstash) ---
REDIS_URL=redis://localhost:6379
