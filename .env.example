# --- Backend (FastAPI) ---
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=...
