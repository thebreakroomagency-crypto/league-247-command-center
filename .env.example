# --- Google APIs ---
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_SHEETS_SPREADSHEET_ID=...
GOOGLE_CALENDAR_ID=primary

# --- GoHighLevel (LeadConnector) ---
GHL_API_KEY=...
GHL_LOCATION_ID=...
